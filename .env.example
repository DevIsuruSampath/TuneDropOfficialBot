# Telegram
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:telegram_bot_token
PRIVATE_CHANNEL_ID=-1001234567890
SONG_CACHE_CHANNEL_ID=-1001234567890
BOT_SESSION_NAME=music_downloader_bot
ADMIN_USER_IDS=123456789

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=tunedrop

# Web Server
WEB_HOST=0.0.0.0
WEB_PORT=8080
DOWNLOAD_BASE_URL=https://your-domain.example

# Docker (Traefik + Watchtower)
TUNEDROP_DOMAIN=tunedrop.yourdomain.com
TRAEFIK_ACME_EMAIL=you@example.com

# Bot Settings
DEFAULT_USER_SPEED_KBPS=100
MAX_PLAYLIST_ITEMS=100
PROGRESS_UPDATE_INTERVAL=2.5
AUTO_CLEANUP_MINUTES=30
LOG_LEVEL=INFO

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTDL_COOKIE_FILE=
YTDLP_COOKIE_FILE=
