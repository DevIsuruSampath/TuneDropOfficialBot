# Telegram
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:telegram_bot_token
PRIVATE_CHANNEL_ID=-1001234567890
SONG_CACHE_CHANNEL_ID=-1001234567890
BOT_SESSION_NAME=music_downloader_bot
ADMIN_USER_IDS=123456789

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=tunedrop

# Web Server
WEB_HOST=0.0.0.0
WEB_PORT=8080
DOWNLOAD_BASE_URL=https://your-domain.example

# Docker (Traefik)
TUNEDROP_DOMAIN=tunedrop.yourdomain.com
TRAEFIK_ACME_EMAIL=you@example.com

# Ads
ADS_ENABLED=false

# Desktop top banner (default keeps existing 728x90 slot)
WEB_ADS_DESKTOP_TOP_BANNER_KEY=f0c271d2355a57b29b6b278209294341
WEB_ADS_DESKTOP_TOP_BANNER_INVOKE_URL=https://cardinaltangible.com/f0c271d2355a57b29b6b278209294341/invoke.js
WEB_ADS_DESKTOP_TOP_BANNER_WIDTH=728
WEB_ADS_DESKTOP_TOP_BANNER_HEIGHT=90

# Desktop inline banner (default keeps existing 300x250 slot)
WEB_ADS_DESKTOP_INLINE_BANNER_KEY=360f27a067037e47107b2b725150e7b5
WEB_ADS_DESKTOP_INLINE_BANNER_INVOKE_URL=https://cardinaltangible.com/360f27a067037e47107b2b725150e7b5/invoke.js
WEB_ADS_DESKTOP_INLINE_BANNER_WIDTH=300
WEB_ADS_DESKTOP_INLINE_BANNER_HEIGHT=250

# Mobile top banner (default keeps existing 320x50 slot)
WEB_ADS_MOBILE_TOP_BANNER_KEY=d76c947d5bce357e40ad06c5443da535
WEB_ADS_MOBILE_TOP_BANNER_INVOKE_URL=https://cardinaltangible.com/d76c947d5bce357e40ad06c5443da535/invoke.js
WEB_ADS_MOBILE_TOP_BANNER_WIDTH=320
WEB_ADS_MOBILE_TOP_BANNER_HEIGHT=50

# Mobile bottom banner (default keeps existing 300x250 slot)
WEB_ADS_MOBILE_BOTTOM_BANNER_KEY=360f27a067037e47107b2b725150e7b5
WEB_ADS_MOBILE_BOTTOM_BANNER_INVOKE_URL=https://cardinaltangible.com/360f27a067037e47107b2b725150e7b5/invoke.js
WEB_ADS_MOBILE_BOTTOM_BANNER_WIDTH=300
WEB_ADS_MOBILE_BOTTOM_BANNER_HEIGHT=250

# Bot Settings
DEFAULT_USER_SPEED_KBPS=100
MAX_PLAYLIST_ITEMS=100
PROGRESS_UPDATE_INTERVAL=2.5
AUTO_CLEANUP_MINUTES=30
LOG_LEVEL=INFO

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTDL_COOKIE_FILE=
YTDLP_COOKIE_FILE=
